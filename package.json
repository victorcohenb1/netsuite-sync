{
  "name": "netsuite-sync",
  "version": "1.0.0",
  "description": "Production backend for NetSuite data extraction, storage, and API serving",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "netsuite",
    "sync",
    "erp"
  ],
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.19.2",
    "crypto-js": "^4.2.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "googleapis": "^171.4.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "oauth-1.0a": "^2.2.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
