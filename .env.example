# ── Server ──────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Database (Supabase / PostgreSQL) ───────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/netsuite_sync

# ── NetSuite OAuth 1.0 / Token-Based Auth ──────────────
NETSUITE_ACCOUNT_ID=YOUR_ACCOUNT_ID
NETSUITE_CONSUMER_KEY=YOUR_CONSUMER_KEY
NETSUITE_CONSUMER_SECRET=YOUR_CONSUMER_SECRET
NETSUITE_TOKEN_ID=YOUR_TOKEN_ID
NETSUITE_TOKEN_SECRET=YOUR_TOKEN_SECRET
NETSUITE_REST_BASE_URL=https://YOUR_ACCOUNT_ID.suitetalk.api.netsuite.com/services/rest

# ── CSV Export RESTlet (NetStock-style) ────────────────
# GET-based RESTlet URL including script & deploy params.
NETSUITE_CSV_RESTLET_URL=https://YOUR_ACCOUNT_ID.restlets.api.netsuite.com/app/site/hosting/restlet.nl?script=SCRIPT_ID&deploy=1
# File Cabinet folder ID where the RESTlet writes CSV exports.
NETSUITE_CSV_FOLDER_ID=YOUR_FOLDER_ID

# ── Sync Settings ──────────────────────────────────────
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_DELAY_MS=2000
SYNC_DEFAULT_CRON=0 */4 * * *
